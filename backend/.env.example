PORT=3000
DATABASE_URL=postgresql://postgres:password@localhost:5432/cococare
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
FUSION_CONFIDENCE_THRESHOLD=0.75

# AWS S3 (optional — falls back to data URL storage)
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Azure Custom Vision (stub used when empty)
AZURE_CV_ENDPOINT=
AZURE_CV_KEY=

# RAG + BERT (BERT required for ingest and chat; set BERT_REQUIRED=false only for emergency)
BERT_MODEL_NAME=Xenova/paraphrase-multilingual-MiniLM-L12-v2
BERT_REQUIRED=true
RAG_TOP_K=8
RAG_MIN_SCORE=0.5
KNOWLEDGE_DATA_DIR=./data/cri-manuals

# OpenWeatherMap (https://openweathermap.org/api)
OPENWEATHER_API_KEY=
