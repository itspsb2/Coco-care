PORT=3000
DATABASE_URL=postgresql://postgres:password@localhost:5432/cococare
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
FUSION_CONFIDENCE_THRESHOLD=0.75

# AWS S3 (optional — falls back to data URL storage)
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Azure Custom Vision — leaf disease ML model
AZURE_CV_ENDPOINT=https://cococare.cognitiveservices.azure.com/
AZURE_CV_KEY=
AZURE_CV_PREDICTION_URL=https://cococare-prediction.cognitiveservices.azure.com/customvision/v3.0/Prediction/850dbacc-7345-497a-9ecc-5510c7f30296/classify/iterations/Iteration2/url

# RAG embeddings (Google Gemini — required for ingest and chat)
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_ENABLED=true
GEMINI_EMBEDDING_DIMENSIONS=768
RAG_TOP_K=8
RAG_MIN_SCORE=0.5
KNOWLEDGE_DATA_DIR=./data/cri-manuals

# OpenWeatherMap (https://openweathermap.org/api)
OPENWEATHER_API_KEY=

# Groq — grounded answer generation after Gemini retrieval (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_ENABLED=true

# Nearby disease alert radius when an officer verifies a report (km)
DISEASE_ALERT_RADIUS_KM=25
